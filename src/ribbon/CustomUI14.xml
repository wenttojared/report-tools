<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="Ribbon_OnLoad">
  <ribbon>
    <tabs>
      <tab id="tabReportTools" label="Report Tools">

        <group id="grpMacros" label="Macros">
          <!-- FINANCE -->
          <menu id="mnuFinance" label="Finance Reports" imageMso="AccountingFormat">
            <!-- BUDGET-->
            <menu id="mnuFinBudget" label="Budget">
              <menu id="mnuFinBudget_Budget04" label="Budget04" imageMso="TableInsert">
                <button id="btnFinance_Budget04Import"
                    label="Prepare Import"
                    imageMso="TableInsert"
                    onAction="Ribbon_Run" />
                <menuSeparator id="sepFinBudget04" />
                <button id="btnGuide_Budget04Import"
                    label="Prepare Import Settings"
                    imageMso="Info"
                    onAction="Ribbon_Guide" />
              </menu>
            </menu>
            <!-- FISCAL -->
            <menu id="mnuFinFiscal" label="Fiscal">
              <menu id="mnuFinFiscal_Fiscal05" label="Fiscal05" imageMso="TableInsert">
                <button id="btnFinance_Fiscal05"
                    label="Convert Report"
                    imageMso="TableInsert"
                    onAction="Ribbon_Run" />
              </menu>
            </menu>

          </menu>
          <!-- HR/PAYROLL -->
          <menu id="mnuHRPay" label="HR/Payroll Reports" imageMso="ContactPictureMenu">
            <!-- BENEFITS -->
            <menu id="mnuHRBenefits" label="Benefits">
              <menu id="mnuHRBenefits_Ben02" label="Ben02" imageMso="TableInsert">
                <button id="btnHRPayroll_Ben02"
                    label="Convert Report"
                    imageMso="TableInsert"
                    onAction="Ribbon_Run" />
              </menu>
            </menu>
            <!-- PAYROLL -->
            <menu id="mnuHRPayroll" label="Payroll">
              <menu id="mnuHRPayroll_Pay03" label="Pay03" imageMso="TableInsert">
                <button id="btnHRPayroll_Pay03"
                    label="Convert Report"
                    imageMso="TableInsert"
                    onAction="Ribbon_Run" />
              </menu>
              <menu id="mnuHRPayroll_Pay13" label="Pay13" imageMso="TableInsert">
                <button id="btnHRPayroll_Pay13"
                    label="Convert Report"
                    imageMso="TableInsert"
                    onAction="Ribbon_Run" />
              </menu>
              <menu id="mnuHRPayroll_Pay14" label="Pay14" imageMso="TableInsert">
                <button id="btnHRPayroll_Pay14"
                    label="Convert Report"
                    imageMso="TableInsert"
                    onAction="Ribbon_Run" />
              </menu>
            </menu>
            <!-- POSITION CONTROL -->
            <menu id="mnuHRPositionControl" label="Position Control">
              <menu id="mnuHRPositionControl_Pos04" label="Pos04" imageMso="TableInsert">
                <button id="btnHRPayroll_Pos04"
                    label="Convert Report"
                    imageMso="TableInsert"
                    onAction="Ribbon_Run" />
              </menu>
            </menu>

          </menu>
        </group>

        <!-- UTILITIES -->
        <group id="grpTools" label="Utilities">
          <button id="btnExportSettings" label="Export Settings" imageMso="AutoFormatDialog" onAction="Ribbon_ExportSettings"/>
          <button id="btnAbout" label="About / Version" imageMso="Info" onAction="Ribbon_About"/>
        </group>

      </tab>
    </tabs>
  </ribbon>
</customUI>